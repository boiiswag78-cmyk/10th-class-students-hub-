{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "streak": { "type": "number", "description": "Current daily study streak" },
        "lastStudyDate": { "type": "string", "format": "date", "description": "Last date the student was active (YYYY-MM-DD)" }
      },
      "required": ["uid", "email"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Student study activities",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["quiz", "study", "task"] },
        "title": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "title", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Global activity feed (filtered by userId in rules)"
    }
  }
}
